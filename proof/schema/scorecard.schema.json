{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://doe.dev/schemas/scorecard-1.0.json",
  "title": "DOE Proof Scorecard",
  "description": "Additive-only governance: adding new fields never bumps the version. Removing or renaming a field bumps schemaVersion -- and this rule is in force from the first external consumer onward. The economics/cost fields were removed during pre-consumer finalization (no consumer depended on them; the HQ consumer is not built yet), which is why this remains 1.0. Consumers (standalone HTML card, HQ) key off schemaVersion and ignore unknown fields.",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "project",
    "generatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$"
    },
    "kind": {
      "enum": [
        "framework-benchmark",
        "project-metrics"
      ]
    },
    "project": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "repo": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "catchRate": {
      "type": "object",
      "required": [
        "injected",
        "caught",
        "rate"
      ],
      "properties": {
        "injected": {
          "type": "integer",
          "minimum": 0
        },
        "caught": {
          "type": "integer",
          "minimum": 0
        },
        "rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "byGate": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "gate",
              "defectClass",
              "injected",
              "caught"
            ],
            "properties": {
              "gate": {
                "type": "string"
              },
              "defectClass": {
                "type": "string"
              },
              "injected": {
                "type": "integer",
                "minimum": 0
              },
              "caught": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "control": {
          "type": "object",
          "required": [
            "injected",
            "caught",
            "rate"
          ],
          "properties": {
            "injected": {
              "type": "integer",
              "minimum": 0
            },
            "caught": {
              "type": "integer",
              "minimum": 0
            },
            "rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "dora": {
      "type": "object",
      "required": [
        "changeFailureRate",
        "reworkRate"
      ],
      "properties": {
        "changeFailureRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reworkRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "leadTimeHours": {
          "type": "number",
          "minimum": 0
        },
        "deployFrequencyPerWeek": {
          "type": "number",
          "minimum": 0
        },
        "window": {
          "type": "object",
          "properties": {
            "from": {
              "type": "string",
              "format": "date-time"
            },
            "to": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "defectsCaught": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "class",
          "gate"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "class": {
            "type": "string"
          },
          "gate": {
            "type": "string"
          },
          "caughtAt": {
            "type": "string"
          }
        }
      }
    },
    "ablation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ceremony",
          "marginalCatch",
          "verdict"
        ],
        "properties": {
          "ceremony": {
            "type": "string"
          },
          "marginalCatch": {
            "type": "integer"
          },
          "verdict": {
            "enum": [
              "load-bearing",
              "candidate-to-cut"
            ]
          }
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "at"
        ],
        "properties": {
          "at": {
            "type": "string"
          },
          "catchRate": {
            "type": "number"
          },
          "changeFailureRate": {
            "type": "number"
          },
          "reworkRate": {
            "type": "number"
          }
        }
      }
    },
    "perception": {
      "type": "object",
      "properties": {
        "dxiScore": {
          "type": [
            "number",
            "null"
          ]
        },
        "frictionFlag": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "framework-benchmark"
          }
        }
      },
      "then": {
        "required": [
          "catchRate"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "project-metrics"
          }
        }
      },
      "then": {
        "required": [
          "dora"
        ]
      }
    }
  ]
}
