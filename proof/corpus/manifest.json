      "value_parts": ["GITHUB_TOKEN = \"ghp_0123456789abcdef", "ghijklmnopqrstuvwxyzABCD\""],
      "benign_value_parts": ["GREETING = \"hello world\""],
      "expect": "block", "covered": true
    },
    {
