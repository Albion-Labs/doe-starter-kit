      "method": "hook",
      "hook": "block_secrets_in_code.py",
      "tool_name": "Write",
      "input_field": "content",
      "input_extra": {
        "file_path": "config.py"
      },
      "value_parts": [
        "GITHUB_TOKEN = \"ghp_0123456789abcdef",
        "ghijklmnopqrstuvwxyzABCD\""
      ],
      "benign_value_parts": [
        "GREETING = \"hello world\""
      ],
      "expect": "block",
      "covered": true
    },
